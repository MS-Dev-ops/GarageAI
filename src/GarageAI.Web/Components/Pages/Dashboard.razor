@page "/garage-ai"

<PageTitle>GarageAI</PageTitle>

<h2>🤖 GarageAI Assistant</h2>

<p class="text-muted">
    Ask questions about your garage in plain English.
</p>

<div class="card p-3">

    <textarea class="form-control"
              rows="4"
              placeholder="Ask GarageAI something..."></textarea>

    <button class="btn btn-primary mt-3">
        Send
    </button>

</div>

<hr />

<div class="card p-3">

    <h5>Conversation</h5>

    <p class="text-muted">
        No messages yet...
    </p>

</div>